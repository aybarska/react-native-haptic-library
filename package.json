{
  "name": "@ayberkmogol/react-native-haptic-library",
  "version": "0.1.5",
  "description": "A React Native haptic feedback library with typed presets and native iOS and Android playback.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "source": "./src/index.ts",
  "files": [
    "src/index.ts",
    "src/NativeHapticLibrary.ts",
    "src/pattern-visualizations.ts",
    "src/patterns.ts",
    "src/presets.ts",
    "src/types.ts",
    "lib",
    "scripts",
    "generated",
    "assets",
    "android/src",
    "android/build.gradle",
    "android/gradle.properties",
    "ios",
    "*.podspec",
    "react-native.config.js"
  ],
  "scripts": {
    "build": "bob build",
    "example:android": "npm --prefix example run android",
    "example:android:assemble": "npm --prefix example run android:assemble",
    "example:ios": "npm --prefix example run ios",
    "example:start": "npm --prefix example run start",
    "example:test": "npm --prefix example run test -- --runInBand",
    "example:typecheck": "npm --prefix example run typecheck",
    "generate:android-patterns": "node scripts/generate-android-patterns.mjs",
    "generate:visualizations": "node scripts/generate-visualizations.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "web:build": "npm --prefix web run build",
    "web:dev": "npm --prefix web run dev",
    "web:preview": "npm --prefix web run preview",
    "prepack": "bob build"
  },
  "keywords": [
    "react-native",
    "haptics",
    "haptic-feedback",
    "ios",
    "android",
    "corehaptics"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayberkmogol/react-native-haptic-library.git"
  },
  "homepage": "https://github.com/ayberkmogol/react-native-haptic-library#readme",
  "bugs": {
    "url": "https://github.com/ayberkmogol/react-native-haptic-library/issues"
  },
  "author": "Ayberk Mogol",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.0.1",
    "@react-native/babel-preset": "^0.81.1",
    "@react-native/eslint-config": "^0.81.1",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.0",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.35.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "react-native": "^0.81.1",
    "react-native-builder-bob": "^0.40.13",
    "typescript": "^5.9.2"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNHapticLibrarySpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.ayberkmogol.hapticlibrary"
    }
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc"
  }
}
